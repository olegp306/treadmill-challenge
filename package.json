{
  "name": "treadmill-challenge",
  "version": "0.5.120",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "description": "Interactive treadmill challenge installation - monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm run dev:local",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:local": "concurrently -n be,fe -c blue,green \"cross-env BACKEND_PORT=3001 ADMIN_PIN=191181 LOCAL_BACKEND_AUTH_TOKEN=local-dev-token pnpm run dev:backend\" \"cross-env FRONTEND_PORT=5173 VITE_API_BASE_URL=http://localhost:3001 pnpm run dev:frontend\"",
    "dev:frontend": "pnpm --dir apps/frontend run dev",
    "dev:backend": "pnpm --dir apps/backend run dev",
    "dev:remote": "concurrently -n rbe,rfe -c magenta,cyan \"cross-env REMOTE_BACKEND_PORT=3002 REMOTE_ADMIN_PIN=191181 REMOTE_JWT_SECRET=remote-dev-secret LOCAL_BACKEND_BASE_URL=http://localhost:3001 LOCAL_BACKEND_AUTH_TOKEN=local-dev-token pnpm run dev:remote-backend\" \"cross-env REMOTE_FRONTEND_PORT=5174 VITE_REMOTE_API_BASE_URL=http://localhost:3002 pnpm run dev:remote-frontend\"",
    "dev:remote-backend": "pnpm --dir apps/remote-backend run dev",
    "dev:remote-frontend": "pnpm --dir apps/remote-frontend run dev",
    "dev:all": "concurrently -n be,fe,rbe,rfe -c blue,green,magenta,cyan \"pnpm run dev:local\" \"pnpm run dev:remote\"",
    "build": "pnpm --recursive --if-present run build",
    "build:shared": "pnpm --dir packages/shared run build",
    "build:backend": "pnpm --dir apps/backend run build",
    "build:frontend": "pnpm --dir apps/frontend run build",
    "build:remote-backend": "pnpm --dir apps/remote-backend run build",
    "build:remote-frontend": "pnpm --dir apps/remote-frontend run build",
    "check:frontend-src-js": "node scripts/check-no-stray-frontend-js.mjs",
    "start:backend": "pnpm --dir apps/backend run start",
    "start:remote-backend": "pnpm --dir apps/remote-backend run start",
    "preview:frontend": "pnpm --dir apps/frontend run preview",
    "preview:remote-frontend": "pnpm --dir apps/remote-frontend run preview",
    "print-dev-qr": "node scripts/print-dev-qr.mjs",
    "td:callback:smoke": "node scripts/td-callback-smoke.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "release:patch": "node scripts/bump-version.mjs patch",
    "release:minor": "node scripts/bump-version.mjs minor",
    "release:major": "node scripts/bump-version.mjs major"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
