# Backend server
PORT=3001
HOST=0.0.0.0

# Optional: SQLite path (default: ./data/treadmill.db relative to backend cwd)
# DB_PATH=./data/treadmill.db

# Optional: secure TouchDesigner finish callback endpoint (/api/touchdesigner/run-result)
# If set, backend requires this token in X-TD-Token or Authorization: Bearer <token>.
# TD_CALLBACK_TOKEN=change-me

# TouchDesigner OSC (backend → TD and TD → backend on local UDP port)
# TD_ADAPTER=mock
# TD_OSC_HOST=127.0.0.1
# TD_OSC_PORT=7000
# TD_OSC_START_ADDRESS=/treadmill/start
# TD_OSC_RUN_SESSION_ADDRESS=/treadmill/runSession
# Inbound on backend (TouchDesigner sends here):
# TD_OSC_ACK_LOCAL_PORT=7001
# TD_OSC_ACK_ADDRESS=/treadmill/ack
# TD_OSC_RUN_STATE_ADDRESS=/treadmill/runState
# TD_OSC_RUN_STATE_DISABLED=false
# TD_OSC_ACK_DISABLED=false
# TD_OSC_ACK_TIMEOUT_MS=30000
# After runSession, if no ack/runState: busy (session stays queued) | unknown (legacy) | free
# TD_OSC_ACK_TIMEOUT_RESOLVES_TO=busy
