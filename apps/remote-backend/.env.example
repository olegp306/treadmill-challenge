REMOTE_BACKEND_PORT=3002
HOST=0.0.0.0

# Remote admin auth
REMOTE_ADMIN_PIN=191181
REMOTE_JWT_SECRET=remote-dev-secret
REMOTE_CORS_ORIGIN=*

# Local backend connection (source of truth)
LOCAL_BACKEND_BASE_URL=http://localhost:3001
LOCAL_BACKEND_AUTH_TOKEN=local-dev-token

# Backup mirror (remote stores only mirrored backups)
REMOTE_BACKUP_ENABLED=true
REMOTE_BACKUP_INTERVAL_MINUTES=60
REMOTE_BACKUP_RETENTION_COUNT=24

# Host monitoring ingest auth (required for POST /api/monitoring/health)
HEALTH_API_KEY=change-me

# Alerts (optional)
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
# ALERT_EMAIL_TO=alerts@example.com
# ALERT_EMAIL_FROM=remote-backend@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
